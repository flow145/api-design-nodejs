{
  "name": "api-design-nodejs",
  "version": "1.0.0",
  "description": "Habit Tracker API for Node.js course",
  "main": "src/index.ts",
  "type": "module",
  "homepage": "https://github.com/flow145/api-design-nodejs#readme",
  "bugs": "https://github.com/flow145/api-design-nodejs/issues",
  "repository": "git@github.com:flow145/api-design-nodejs.git",
  "scripts": {
    "dev": "node --watch src/index.ts",
    "start": "node src/index.ts",
    "format": "biome format --reporter=summary",
    "format:fix": "pnpm format --write",
    "check": "biome check --reporter=summary",
    "check:fix": "pnpm check --write",
    "typecheck": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@epic-web/remember": "^1.1.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "custom-env": "^2.0.6",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.44.4",
    "drizzle-zod": "^0.8.3",
    "express": "^5.1.0",
    "helmet": "^7.1.0",
    "jose": "^6.0.12",
    "morgan": "^1.10.1",
    "pg": "^8.16.3",
    "ts-node": "^10.9.2",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.11.5",
    "@types/supertest": "^6.0.2",
    "cross-env": "^10.0.0",
    "drizzle-kit": "^0.31.4",
    "lefthook": "^2.1.5",
    "supertest": "^6.3.4",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
